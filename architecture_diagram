// MedNexus AI Architecture
digraph {
	nodesep=0.6 rankdir=TB ranksep=0.8
	node [fillcolor=white fontname=Arial shape=box style="rounded,filled"]
	subgraph cluster_frontend {
		color=blue fontname="Arial-Bold" label="FRONTEND LAYER
HTML/CSS/JavaScript Interface" margin=20 style=dashed
		Input [label="Patient Input
[Voice Input] [Image Capture]" fillcolor="#E3F2FD"]
	}
	subgraph cluster_backend {
		color=green fontname="Arial-Bold" label="BACKEND LAYER" margin=20 style=dashed
		Flask [label="Flask Orchestration Server" fillcolor="#E8F5E9"]
	}
	subgraph cluster_execution {
		color=purple fontname="Arial-Bold" label="AGENTIC EXECUTION LAYER" margin=20 style=dashed
		LangGraph [label=LangGraph fillcolor="#F3E5F5" shape=cylinder]
		subgraph cluster_agents {
			color=black fontname="Arial-Bold" label="Specialist Agents:" style=dotted
			ENT [label=ENT fillcolor="#FCE4EC"]
			Derm [label=Derm fillcolor="#FCE4EC"]
			Psych [label=Psych fillcolor="#FCE4EC"]
			Pharm [label=Pharm fillcolor="#FCE4EC"]
			GP [label=GP fillcolor="#FCE4EC"]
		}
	}
	subgraph cluster_knowledge {
		color=orange fontname="Arial-Bold" label="KNOWLEDGE LAYER" margin=20 style=dashed
		subgraph cluster_pinecone {
			color=black fontname="Arial-Bold" label="Pinecone Vector DB:" style=dotted
			NDerm [label="Dermatology Namespace" fillcolor="#FFF3E0"]
			NENT [label="ENT Namespace" fillcolor="#FFF3E0"]
			NPsych [label="Psychiatry Namespace" fillcolor="#FFF3E0"]
		}
		SQLite [label="SQLite
Checkpointing" fillcolor="#FFF3E0" shape=cylinder]
		Tavily [label="Tavily API
Web Search" fillcolor="#FFF3E0"]
	}
	Input -> Flask [lhead=cluster_backend ltail=cluster_frontend]
	Flask -> LangGraph
	LangGraph -> ENT
	LangGraph -> Derm
	LangGraph -> Psych
	LangGraph -> Pharm
	LangGraph -> GP
	LangGraph -> SQLite [ltail=cluster_execution]
	LangGraph -> Tavily [ltail=cluster_execution]
	Derm -> NDerm [style=dashed]
	ENT -> NENT [style=dashed]
	Psych -> NPsych [style=dashed]
}
